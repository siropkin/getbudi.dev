{
  "name": "getbudi-dev",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Marketing landing page for budi — local-first cost analytics for AI coding agents.",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build && npx pagefind --site dist && npm run audit && npm run csp",
    "preview": "astro preview",
    "astro": "astro",
    "check": "astro check",
    "audit": "node scripts/build/audit-build.mjs dist",
    "csp": "node scripts/build/generate-csp.mjs dist",
    "generate-assets": "node scripts/generate/generate-assets.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "test": "node --test test/*.test.mjs"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/sitemap": "^3.7.2",
    "@tailwindcss/vite": "^4.3.0",
    "@vercel/analytics": "^2.0.1",
    "astro": "^6.3.3",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@resvg/resvg-js": "^2.6.2",
    "eslint": "^10.4.0",
    "eslint-plugin-astro": "^1.7.0",
    "globals": "^17.6.0",
    "node-html-parser": "^7.1.0",
    "pagefind": "^1.3.0",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "typescript-eslint": "^8.59.3"
  },
  "overrides": {
    "vite": "^7.3.3"
  }
}
