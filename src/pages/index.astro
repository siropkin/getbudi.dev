---
import Base from "~/layouts/Base.astro";
import CopyableCommand from "~/components/CopyableCommand.astro";
import OsInstallTabs from "~/components/OsInstallTabs.astro";
import EditorInstallCards from "~/components/EditorInstallCards.astro";
import GitHubIcon from "~/components/GitHubIcon.astro";
import JsonLd from "~/components/JsonLd.astro";
import { ANCHORS, anchorHref } from "~/lib/anchors";

const faqs = [
  {
    q: "What leaves my machine when using Budi?",
    a: "By default, nothing. Optionally, only pre-aggregated daily numbers (tokens, cost, model, hashed repo ID, branch, ticket ID). Never prompts, code, responses, file paths, or emails.",
  },
  {
    q: "Is it free?",
    a: "Yes for solo use. The budi daemon and CLI are open source (MIT) and free forever — self-hosted, no signup. The optional cloud dashboard at app.getbudi.dev is free for personal use: sign up, get a workspace, push aggregates from your machine. Paid plans cover teams that share a workspace and need multi-seat dashboards.",
  },
  {
    q: "Does budi work in VS Code, Cursor, and JetBrains?",
    a: "Yes. One extension covers Cursor and VS Code (v8.4.0+, May 2026); a sibling Kotlin plugin covers JetBrains IDEs via the JetBrains Marketplace. Use whichever editor you use day-to-day — a user with multiple installed sees each host's own data in its status bar.",
  },
  {
    q: "What about GitHub Copilot?",
    a: "Copilot Chat is supported in 8.4.0 — real per-message tokens parsed from VS Code's local session files. GitHub-side dollar reconciliation works for individually-licensed users via the GitHub Billing API; org-managed users see local-tail tokens priced through budi's pricing manifest.",
  },
  {
    q: "Do I need a GitHub PAT for Copilot Chat?",
    a: "Optional, but recommended for accuracy. Without a PAT, on May-2026+ VS Code builds you get output-only token dollars — useful as a relative trend, but typically a fraction of the actual bill. With a PAT scoped to billing, budi reconciles to GitHub's exact dollar number per (date, model) bucket. Org-managed licences see output-only forever (the user-level Billing API endpoint is empty for them).",
  },
  {
    q: "What about Continue / Cline / Roo Code / Aider / Gemini CLI?",
    a: "Planned for 8.5.0 (the breadth round). Same provider-plugin pattern as Cursor and Copilot Chat — local logs primary, no proxy.",
  },
];

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: {
      "@type": "Answer",
      text: f.a,
    },
  })),
};

const installCommands = {
  macos: "brew install siropkin/budi/budi && budi init",
  linux:
    "curl -fsSL https://raw.githubusercontent.com/siropkin/budi/main/scripts/install-standalone.sh | bash && budi init",
  windows:
    "irm https://raw.githubusercontent.com/siropkin/budi/main/scripts/install-standalone.ps1 | iex; budi init",
};

let LATEST_BUDI_VERSION = "v8.4.2";
try {
  const res = await fetch("https://api.github.com/repos/siropkin/budi/releases/latest", {
    signal: AbortSignal.timeout(5000),
  });
  if (res.ok) {
    const data = await res.json();
    if (typeof data.tag_name === "string" && /^v\d+\.\d+\.\d+/.test(data.tag_name)) {
      LATEST_BUDI_VERSION = data.tag_name;
    }
  }
} catch {
  // keep fallback
}
const features = [
  {
    title: "Multi-agent, no interception",
    body: "Claude Code, Codex CLI, Copilot CLI, and Cursor — all attributed by the same daemon. Reads the transcript files those tools already write to disk. Nothing in your network path.",
    foot: "Reads transcripts from disk — no proxy",
  },
  {
    title: "Per repo, branch, and ticket",
    body: "Cost attributed to the repo and branch you were on, with ticket IDs lifted from branch names. Filter by ticket, activity, file, model, or custom tag.",
    foot: "budi stats branch · ticket · file",
  },
  {
    title: "Live status line",
    body: "Rolling 1d / 7d / 30d cost in Claude Code, Cursor, VS Code, and JetBrains IDEs — scoped per host. The Cursor line shows Cursor spend only; the VS Code and JetBrains lines show their own Copilot Chat spend only.",
    foot: "_projects/budi · main · budi · $3.47 session · $0.06 message",
  },
  {
    title: "Session health on demand",
    body: "budi sessions <id> shows context growth, cache reuse, cost acceleration, and retry loops in plain English. Not a wall of emoji by default — quiet unless you ask.",
    foot: "budi sessions <id>",
  },
];

const alternatives = [
  {
    name: "Provider dashboards",
    examples: "Anthropic Console · OpenAI usage · Cursor usage",
    good: "Official, authoritative totals. Free.",
    gap: "Single-provider. No repo, branch, or ticket attribution. Nothing cross-agent.",
    kind: "alt" as const,
  },
  {
    name: "Open-source CLI usage tools",
    examples: "ccusage · codeburn · claude-usage",
    good: "Local, lightweight, correct for the one agent they target.",
    gap: "Single-agent. No cross-agent rollups, no branch/ticket attribution, no team view.",
    kind: "alt" as const,
  },
  {
    name: "SaaS cost trackers that upload prompts",
    examples: "Generic observability vendors that ingest LLM payloads",
    good: "Central dashboard with deep analytics.",
    gap: "Your prompts, code, and responses leave your machine — a hard no for most source code.",
    kind: "alt" as const,
  },
  {
    name: "Budi",
    examples: "Local daemon · transcript tailing · multi-agent · opt-in cloud",
    good: "Multi-agent via local transcript tailing — nothing in your network path. Repo/branch/ticket attribution. Live session health vitals. Optional team dashboard with aggregates only.",
    gap: "You run a small daemon. Live rows lag by seconds; Cursor cost can additionally lag ~10 min via the Cursor Usage API. Not every agent supported yet (Gemini deferred).",
    kind: "budi" as const,
  },
];

const firstRunSteps = [
  {
    n: "1",
    cmd: "budi init",
    body: "Starts the daemon on port 7878 and installs the platform-native autostart service. The hero install runs this for you — listed here so you know what just happened.",
  },
  {
    n: "2",
    cmd: "budi integrations install",
    body: "Wires the Claude Code statusline and offers the VS Code / Cursor extension if either editor is detected. Restart Claude Code afterwards so it picks up the new statusLine command.",
  },
  {
    n: "3",
    cmd: "budi doctor",
    body: 'End-to-end verifier: daemon, tailers, schema, transcript visibility, and attribution health. When "All checks passed." you are done.',
  },
  {
    n: "4",
    cmd: "budi status",
    body: "Today-cost snapshot: daemon state and today's spend. For the full breakdown, use budi stats projects / branches / tickets.",
  },
];

const providers = [
  {
    name: "Cursor",
    live: true,
    source: "Local SQLite + Cursor Usage API",
  },
  {
    name: "Claude Code",
    live: true,
    source: "Local JSONL transcripts",
  },
  {
    name: "Codex CLI",
    live: true,
    source: "Local JSONL transcripts",
  },
  {
    name: "Copilot CLI",
    live: true,
    source: "Local JSONL session-state",
  },
  {
    name: "Copilot Chat (VS Code)",
    live: true,
    source: "Local JSON/JSONL + GitHub Billing API",
  },
  {
    name: "Continue, Cline, Roo Code, Aider, Gemini CLI",
    live: false,
    source: "Local logs",
  },
];

const altInstalls = [
  {
    label: "Bundled extension via budi CLI",
    note: "Same path budi init uses. Picks the right editor automatically.",
    code: "budi integrations install --with cursor-extension",
  },
  {
    label: "Manual VSIX in VS Code (offline / pinned)",
    note: "Download cursor-budi.vsix from the budi-cursor releases page first.",
    code: "code --install-extension cursor-budi.vsix --force",
  },
  {
    label: "Manual VSIX in Cursor (offline / pinned)",
    note: "Same VSIX file works in Cursor — Open VSX is just a discovery surface.",
    code: "cursor --install-extension cursor-budi.vsix --force",
  },
  {
    label: "Daemon from source (Rust toolchain)",
    code: "git clone https://github.com/siropkin/budi.git && cd budi && ./scripts/install.sh",
  },
];
---

<Base>
  <JsonLd data={faqJsonLd} />

  {/* 1. HERO */}
  <section class="container-readable pt-16 pb-14 sm:pt-24 sm:pb-20">
    <div class="flex max-w-3xl flex-col items-start gap-6 sm:gap-8">
      <span class="chip">
        <span aria-hidden="true" class="bg-accent inline-block h-1.5 w-1.5 rounded-full"></span>
        Free · self-hosted · no signup · open source (MIT)
      </span>

      <h1
        class="text-[2.25rem] leading-[1.05] font-semibold tracking-tight text-balance sm:text-[3.25rem]"
      >
        Local-first cost tracker for
        <span class="text-accent">AI coding agents.</span>
      </h1>

      <div class="flex flex-wrap items-center gap-2 text-sm">
        <span class="text-fg-dim text-xs tracking-[0.18em] uppercase">Tracks</span>
        {
          ["Cursor", "Claude Code", "Codex", "Copilot Chat"].map((agent) => (
            <span class="chip border-line-strong text-fg">{agent}</span>
          ))
        }
      </div>

      <p class="text-fg-muted text-lg leading-relaxed text-pretty sm:text-xl">
        After <code
          class="bg-surface-3 border-line/70 text-fg rounded border px-1.5 py-0.5 font-mono text-[0.95em]"
          >brew install</code
        >, three things run on your machine: a small daemon that tails the transcripts your agents
        already write to disk, a status bar in your editor, and a CLI for repo / branch / ticket
        attribution. Nothing in your network path.
      </p>
    </div>

    {
      /*
      Mobile/tablet (< lg): show the terminal screenshot first, then install + nav row.
      Desktop (lg+): keep the original install → nav → terminal order. See issue #100.
    */
    }
    <div class="mt-6 flex flex-col gap-6 sm:mt-8 sm:gap-8">
      <div class="order-2 lg:order-1">
        <OsInstallTabs id="install-hero" commands={installCommands} variant="hero" />
        <p class="text-fg-dim mt-2 flex flex-wrap items-center gap-x-2 gap-y-1 text-xs">
          <span>Installs <code class="text-fg-muted text-[11px]">{LATEST_BUDI_VERSION}</code>.</span
          >
          <span>
            One command. macOS / Linux / Windows. No account needed.
            <a href={anchorHref(ANCHORS.install)} class="link-underline hover:text-fg"
              >Editor wiring →</a
            >
          </span>
        </p>
      </div>

      <div class="order-3 flex max-w-3xl flex-wrap items-center gap-3 text-sm lg:order-2">
        <a
          href="https://github.com/siropkin/budi"
          target="_blank"
          rel="noopener noreferrer"
          class="border-line-strong hover:border-accent hover:text-accent inline-flex items-center gap-2 rounded-lg border px-4 py-2 transition-colors"
        >
          <GitHubIcon />
          View on GitHub
        </a>
        <a
          href={anchorHref(ANCHORS.teams)}
          class="text-fg-muted hover:text-fg inline-flex items-center gap-1 px-3 py-2"
        >
          Cloud dashboard →
        </a>
        <a
          href={anchorHref(ANCHORS.compare)}
          class="text-fg-muted hover:text-fg inline-flex items-center gap-1 px-3 py-2"
        >
          Why not just X? ↓
        </a>
      </div>

      <div class="card order-1 overflow-hidden lg:order-3 lg:mt-4">
        <div
          class="border-line bg-surface-3 text-fg-dim flex items-center gap-2 border-b px-4 py-2.5 text-xs"
        >
          <span class="inline-block h-2.5 w-2.5 rounded-full bg-[#ff5f57]"></span>
          <span class="inline-block h-2.5 w-2.5 rounded-full bg-[#febc2e]"></span>
          <span class="inline-block h-2.5 w-2.5 rounded-full bg-[#28c840]"></span>
          <span class="ml-3 font-mono">~ budi stats project</span>
        </div>
        <pre
          class="terminal-scroll text-fg m-0 overflow-x-auto px-4 py-5 text-[12.5px] leading-[1.55] sm:px-6 sm:py-6 sm:text-[13.5px]"><code>{`Today                                           7d        30d
─────────────────────────────────────────────────────────────────
$ 4.92 session    🟢 healthy        $ 38.10    $ 162.44

Top repos (last 7d)                          cost      msgs
─────────────────────────────────────────────────────────────────
siropkin/budi                              $ 18.40    21,402
acme/web                                   $ 11.05     9,118
acme/infra                                 $  6.32     2,845
personal/notes                             $  2.33       661

Top models (last 7d)                         cost     share
─────────────────────────────────────────────────────────────────
claude-opus-4-7                            $ 22.18    58.2 %
claude-sonnet-4-6                          $  9.41    24.7 %
claude-haiku-4-5                           $  4.02    10.6 %
gpt-5-codex                                $  2.49     6.5 %

Branch hot list                              cost    ticket
─────────────────────────────────────────────────────────────────
budi/feat/cloud-ingest                     $  6.91    BUD-214
acme/web/fix/checkout-retry                $  4.38    WEB-1180
acme/web/feat/analytics-v3                 $  3.12    WEB-1199`}</code></pre>
      </div>
    </div>
  </section>

  {/* 3. FEATURES */}
  <section id={ANCHORS.features} class="container-readable border-line/70 border-t py-14 sm:py-20">
    <header class="mb-10 max-w-2xl">
      <p class="text-fg-dim mb-2 text-xs tracking-[0.18em] uppercase">What it does</p>
      <h2 class="text-2xl font-semibold tracking-tight sm:text-3xl">
        Multi-agent. Real attribution. Zero interception.
      </h2>
      <p class="text-fg-muted mt-3">
        Claude Code, Codex CLI, Copilot CLI, and Cursor — tracked by tailing the transcripts each
        agent already writes to disk. No proxy, no gateway, nothing in your network path.
      </p>
    </header>

    <div class="grid gap-4 sm:grid-cols-2">
      {
        features.map((f) => (
          <article class="card flex flex-col gap-3 p-5 sm:p-6">
            <h3 class="text-fg font-semibold tracking-tight">{f.title}</h3>
            <p class="text-fg-muted text-sm leading-relaxed">{f.body}</p>
            <code class="text-fg-dim bg-surface-3 border-line/70 mt-auto self-start rounded-md border px-2 py-1 text-[12px]">
              {f.foot}
            </code>
          </article>
        ))
      }
    </div>

    <figure class="mt-6 grid gap-4 sm:grid-cols-2">
      {
        [
          {
            host: "Cursor",
            file: "payments.ts",
            scope: "cursor",
            statusBg: "bg-[#181818]",
            statusBorder: "border-[#2a2a2a]",
            d1: "$0.42",
            d7: "$3.18",
            d30: "$14.92",
          },
          {
            host: "VS Code",
            file: "payments.ts",
            scope: "copilot_chat",
            statusBg: "bg-[#007ACC]",
            statusBorder: "border-[#005a9e]",
            d1: "$0.31",
            d7: "$2.04",
            d30: "$9.87",
          },
        ].map((s) => (
          <div class="card flex flex-col overflow-hidden">
            <div class="border-line bg-surface-3 text-fg-dim flex items-center gap-2 border-b px-4 py-2.5 text-xs">
              <span class="inline-block h-2.5 w-2.5 rounded-full bg-[#ff5f57]" />
              <span class="inline-block h-2.5 w-2.5 rounded-full bg-[#febc2e]" />
              <span class="inline-block h-2.5 w-2.5 rounded-full bg-[#28c840]" />
              <span class="ml-3 font-mono">
                {s.host} — {s.file}
              </span>
            </div>
            <div class="flex-1 bg-[#1e1e1e] px-4 py-5 font-mono text-[12px] leading-relaxed">
              <p class="text-[#6a9955]">// src/lib/{s.file}</p>
              <p>
                <span class="text-[#c586c0]">export async function</span>{" "}
                <span class="text-[#dcdcaa]">refundCharge</span>
                <span class="text-[#d4d4d4]">(</span>
                <span class="text-[#9cdcfe]">id</span>
                <span class="text-[#d4d4d4]">: </span>
                <span class="text-[#4ec9b0]">string</span>
                <span class="text-[#d4d4d4]">) {"{"}</span>
              </p>
              <p class="pl-4 text-[#d4d4d4]">
                <span class="text-[#c586c0]">return</span> stripe.refunds.
                <span class="text-[#dcdcaa]">create</span>({"{ "}
                <span class="text-[#9cdcfe]">charge</span>: id {"}"});
              </p>
              <p class="text-[#d4d4d4]">{"}"}</p>
            </div>
            <div
              class:list={[
                "flex items-center justify-between gap-3 border-t px-3 py-1 font-mono text-[11px] text-white",
                s.statusBg,
                s.statusBorder,
              ]}
              title={`budi scope: ${s.scope}`}
            >
              <div class="flex items-center gap-3 truncate opacity-90">
                <span>main</span>
                <span class="hidden sm:inline">{s.file}</span>
              </div>
              <div class="flex items-center gap-2 truncate">
                <span aria-hidden="true" class="inline-block h-1.5 w-1.5 rounded-full bg-white" />
                <span>
                  budi · {s.d1} 1d · {s.d7} 7d · {s.d30} 30d
                </span>
              </div>
            </div>
            <figcaption class="text-fg-muted border-line/70 border-t px-4 py-3 text-xs leading-relaxed">
              <strong class="text-fg font-medium">{s.host}</strong> — status bar scoped to{" "}
              <code class="text-[11px]">{s.scope}</code>. Each editor shows only its own host's
              spend.
            </figcaption>
          </div>
        ))
      }
    </figure>

    <figure class="card mt-6 flex flex-col overflow-hidden">
      <div
        class="border-line bg-surface-3 text-fg-dim flex items-center gap-2 border-b px-4 py-2.5 text-xs"
      >
        <span class="inline-block h-2.5 w-2.5 rounded-full bg-[#ff5f57]"></span>
        <span class="inline-block h-2.5 w-2.5 rounded-full bg-[#febc2e]"></span>
        <span class="inline-block h-2.5 w-2.5 rounded-full bg-[#28c840]"></span>
        <span class="ml-3 font-mono">~ budi sessions &lt;id&gt;</span>
      </div>
      <pre
        class="terminal-scroll text-fg m-0 flex-1 overflow-x-auto px-4 py-4 text-[12px] leading-[1.55] sm:text-[12.5px]"><code>{`  Session 2968337c-1e4
  ──────────────────────────────────────────────────
  Agent      claude_code
  Models     claude-opus-4-7
  Started    2026-05-06T02:22:27.194+00:00
  Duration   2m22s
  Repos      github.com/siropkin/budi-cloud
  Branches   151-repos-companion-tables, main
  Outcome    no_commit
             …explanation…

  Messages   22
  Input      32
  Output     10.8K
  Est. cost  $1.70

  Tags
    file_path: src/lib/dal.ts
    …

  🟢 Vitals: GREEN`}</code></pre>
      <figcaption class="text-fg-muted border-line/70 border-t px-4 py-3 text-xs leading-relaxed">
        <code>budi sessions &lt;id&gt;</code> — session health in plain English. No dashboard required.
      </figcaption>
    </figure>
  </section>

  {/* 3b. PROVIDER MATRIX */}
  <section
    id={ANCHORS.providers}
    class="container-readable border-line/70 scroll-mt-24 border-t py-14 sm:py-20"
  >
    <header class="mb-8 max-w-2xl">
      <p class="text-fg-dim mb-2 text-xs tracking-[0.18em] uppercase">What budi tracks</p>
      <h2 class="text-2xl font-semibold tracking-tight sm:text-3xl">Provider coverage.</h2>
      <p class="text-fg-muted mt-3">
        Local logs are the primary source for every provider. Vendor APIs (Cursor Usage, GitHub
        Billing) are used only as supplementary truth-up — so attribution keeps working offline and
        when an upstream API breaks.
      </p>
    </header>

    <div class="card overflow-hidden">
      <table class="w-full text-sm">
        <thead class="text-fg-dim border-line/70 border-b text-xs tracking-wider uppercase">
          <tr>
            <th class="px-4 py-3 text-left font-medium sm:px-5">Provider</th>
            <th class="px-4 py-3 text-left font-medium sm:px-5">Status</th>
            <th class="hidden px-4 py-3 text-left font-medium sm:table-cell sm:px-5">Source</th>
          </tr>
        </thead>
        <tbody>
          {
            providers.map((p, i) => (
              <tr class:list={[i > 0 ? "border-line/70 border-t" : ""]}>
                <td class="text-fg px-4 py-3 font-medium sm:px-5">{p.name}</td>
                <td class="px-4 py-3 sm:px-5">
                  <span
                    class:list={[
                      "chip",
                      p.live ? "border-accent text-accent" : "text-fg-dim",
                    ]}
                  >
                    {p.live ? "Live" : "Coming soon"}
                  </span>
                </td>
                <td class="text-fg-muted hidden px-4 py-3 sm:table-cell sm:px-5">{p.source}</td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>
  </section>

  {/* 4. COMPARE */}
  <section id={ANCHORS.compare} class="container-readable border-line/70 border-t py-14 sm:py-20">
    <header class="mb-10 max-w-2xl">
      <p class="text-fg-dim mb-2 text-xs tracking-[0.18em] uppercase">Why not just use X?</p>
      <h2 class="text-2xl font-semibold tracking-tight sm:text-3xl">
        The realistic alternatives, named honestly.
      </h2>
      <p class="text-fg-muted mt-3">
        If one of these already fits your workflow, use it. Budi exists for the case where you run
        more than one agent, care about per-repo attribution, and are not willing to upload prompts.
      </p>
    </header>

    <div class="grid gap-4 sm:grid-cols-2">
      {
        alternatives.map((alt) => (
          <article
            class:list={[
              "card flex flex-col gap-3 p-5 sm:p-6",
              alt.kind === "budi" ? "border-accent bg-accent-soft/30" : "",
            ]}
          >
            <header class="flex flex-col gap-1">
              <h3
                class:list={[
                  "font-semibold tracking-tight",
                  alt.kind === "budi" ? "text-accent" : "text-fg",
                ]}
              >
                {alt.name}
              </h3>
              <p class="text-fg-dim text-xs leading-snug">{alt.examples}</p>
            </header>
            <dl class="flex flex-col gap-2 text-sm">
              <div>
                <dt class="text-fg-dim mb-0.5 text-xs tracking-wider uppercase">Good at</dt>
                <dd class="text-fg-muted leading-relaxed">{alt.good}</dd>
              </div>
              <div>
                <dt class="text-fg-dim mb-0.5 text-xs tracking-wider uppercase">
                  {alt.kind === "budi" ? "Caveats" : "Stops at"}
                </dt>
                <dd class="text-fg-muted leading-relaxed">{alt.gap}</dd>
              </div>
            </dl>
          </article>
        ))
      }
    </div>
  </section>

  {/* 5. PRIVACY */}
  <section id={ANCHORS.privacy} class="container-readable border-line/70 border-t py-14 sm:py-20">
    <header class="mb-8 max-w-2xl">
      <p class="text-fg-dim mb-2 text-xs tracking-[0.18em] uppercase">Privacy contract</p>
      <h2 class="text-2xl font-semibold tracking-tight sm:text-3xl">Local-first, by design.</h2>
      <p class="text-fg-muted mt-3">
        A small Rust daemon on your machine watches the transcript files your agents already write
        to disk. Nothing sits in your network path. Three things in plain English:
      </p>
    </header>

    <div class="grid gap-4 md:grid-cols-3">
      <div class="card border-l-accent border-l-4 p-5">
        <h3 class="text-fg mb-2 font-semibold">Never leaves</h3>
        <p class="text-fg-muted text-sm leading-relaxed">
          Prompts, code, AI responses, file paths, email addresses, raw payloads, and tag values.
          There is no "full upload" mode in the code.
        </p>
      </div>
      <div class="card border-l-warn border-l-4 p-5">
        <h3 class="text-fg mb-2 font-semibold">Can optionally leave</h3>
        <p class="text-fg-muted text-sm leading-relaxed">
          Pre-aggregated daily numbers — tokens, cost, model name, hashed repo ID, branch name,
          ticket ID. Push-only, HTTPS-only. Off by default.
        </p>
      </div>
      <div class="card border-l-line-strong border-l-4 p-5">
        <h3 class="text-fg mb-2 font-semibold">How to turn it on</h3>
        <p class="text-fg-muted text-sm leading-relaxed">
          Free for personal use — sign up at <a
            href="https://app.getbudi.dev"
            class="link-underline hover:text-fg"
            target="_blank"
            rel="noopener noreferrer">app.getbudi.dev</a
          >, drop your API key into <code class="text-xs">~/.config/budi/cloud.toml</code>, set
          <code class="text-xs">enabled = true</code>, restart the daemon.
        </p>
      </div>
    </div>

    <p id={ANCHORS.analytics} class="text-fg-muted mt-8 scroll-mt-24 text-sm leading-relaxed">
      <strong class="text-fg font-medium">Analytics.</strong>
      This site (<code class="text-xs">getbudi.dev</code>) counts anonymous page views via Vercel
      Web Analytics: cookieless, IP hashed daily, no session replay, no cross-site tracking. It only
      runs on this site — not part of the product.
    </p>
  </section>

  {/* 6. INSTALL */}
  <section id={ANCHORS.install} class="container-readable border-line/70 border-t py-14 sm:py-20">
    <header class="mb-8 max-w-2xl">
      <p class="text-fg-dim mb-2 text-xs tracking-[0.18em] uppercase">Install</p>
      <h2 class="text-2xl font-semibold tracking-tight sm:text-3xl">
        One paste, then four steps to verify.
      </h2>
      <p class="text-fg-muted mt-3">
        The command below installs budi and runs <code>budi init</code> — the daemon is up and the autostart
        service is wired. Editor statusline + extension wiring is the second step in the checklist below.
      </p>
    </header>

    <OsInstallTabs id="install-section" commands={installCommands} variant="hero" />
    <p class="text-fg-dim mt-2 text-xs">
      Installs <code class="text-fg-muted text-[11px]">{LATEST_BUDI_VERSION}</code>. Latest release
      on <a
        href="https://github.com/siropkin/budi/releases"
        class="link-underline hover:text-fg"
        target="_blank"
        rel="noopener noreferrer">GitHub</a
      >. Prefer to install the editor extension on its own?
      <a href={anchorHref(ANCHORS.editorExtension)} class="link-underline hover:text-fg"
        >Pick VS Code or Cursor below</a
      >.
    </p>

    <div class="mt-10">
      <h3 class="text-fg mb-1 text-lg font-semibold tracking-tight">Four steps to verify.</h3>
      <p class="text-fg-muted mb-6 text-sm">
        If anything looks wrong, <code class="text-xs">budi doctor</code> is the source of truth. For
        a live session health read, run <code class="text-xs">budi sessions &lt;id&gt;</code>.
      </p>
      <ol class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4" role="list">
        {
          firstRunSteps.map((step) => (
            <li class="card flex flex-col gap-3 p-5">
              <div class="flex items-center gap-3">
                <span
                  aria-hidden="true"
                  class="bg-accent-soft text-accent inline-flex h-7 w-7 shrink-0 items-center justify-center rounded-full font-mono text-sm font-semibold"
                >
                  {step.n}
                </span>
                <code class="text-fg font-mono text-sm">{step.cmd}</code>
              </div>
              <p class="text-fg-muted text-sm leading-relaxed">{step.body}</p>
            </li>
          ))
        }
      </ol>
    </div>

    <div id={ANCHORS.editorExtension} class="mt-12 scroll-mt-24">
      <h3 class="text-fg mb-1 text-lg font-semibold tracking-tight">Editor extension.</h3>
      <p class="text-fg-muted mb-6 text-sm">
        Adds the budi status bar to VS Code, Cursor, or a JetBrains IDE. <code class="text-xs"
          >budi init</code
        > offers VS Code / Cursor automatically; the JetBrains plugin ships on the JetBrains Marketplace
        and is installed from inside the IDE. Pick your editor:
      </p>
      <EditorInstallCards />
    </div>

    <details class="group mt-10">
      <summary
        class="text-fg-muted hover:text-fg inline-flex cursor-pointer list-none items-center gap-2 text-sm transition-colors"
      >
        <svg
          aria-hidden="true"
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="transition-transform group-open:rotate-90"
        >
          <polyline points="9 18 15 12 9 6"></polyline>
        </svg>
        Other install methods
      </summary>
      <div class="mt-4 grid gap-3">
        {
          altInstalls.map((alt) => (
            <div>
              <div class="text-fg-dim mb-1.5 text-xs tracking-wider uppercase">{alt.label}</div>
              {alt.note && <p class="text-fg-muted mb-2 text-xs leading-relaxed">{alt.note}</p>}
              <CopyableCommand command={alt.code} variant="compact" />
            </div>
          ))
        }
      </div>
    </details>
  </section>

  {/* 7. FOR TEAMS — compact callout */}
  <section
    id={ANCHORS.teams}
    class="container-readable border-line/70 scroll-mt-24 border-t py-10 sm:py-14"
  >
    <div class="card flex flex-col gap-4 p-5 sm:flex-row sm:items-center sm:justify-between sm:p-6">
      <div class="max-w-2xl">
        <p class="text-fg-dim mb-1 text-xs tracking-[0.18em] uppercase">Cloud dashboard (opt-in)</p>
        <h2 class="text-fg text-lg font-semibold tracking-tight sm:text-xl">
          One workspace for your stats — aggregates only, no prompts or code.
        </h2>
        <p class="text-fg-muted mt-2 text-sm leading-relaxed">
          Free for personal use. Daily cost per user, repo, model, branch, and ticket at <a
            href="https://app.getbudi.dev"
            class="link-underline hover:text-fg"
            target="_blank"
            rel="noopener noreferrer">app.getbudi.dev</a
          > — your first workspace is created automatically on signup. Paid plans cover teams that share
          a workspace. <a href={anchorHref(ANCHORS.privacy)} class="link-underline hover:text-fg"
            >Privacy contract</a
          >
          spells out exactly what does and doesn't leave your machine.
        </p>
      </div>
      <a
        href="https://app.getbudi.dev"
        target="_blank"
        rel="noopener noreferrer"
        class="bg-accent inline-flex shrink-0 items-center gap-2 self-start rounded-lg px-4 py-2 text-sm font-semibold text-black transition-opacity hover:opacity-90 sm:self-auto"
      >
        Try the free cloud dashboard
        <svg
          aria-hidden="true"
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.4"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <line x1="7" y1="17" x2="17" y2="7"></line>
          <polyline points="7 7 17 7 17 17"></polyline>
        </svg>
      </a>
    </div>
  </section>

  {/* 8. FAQ */}
  <section
    id={ANCHORS.faq}
    class="container-readable border-line/70 scroll-mt-24 border-t py-14 sm:py-20"
  >
    <header class="mb-8 max-w-2xl">
      <p class="text-fg-dim mb-2 text-xs tracking-[0.18em] uppercase">FAQ</p>
      <h2 class="text-2xl font-semibold tracking-tight sm:text-3xl">
        The questions we keep getting asked.
      </h2>
      <p class="text-fg-muted mt-3">
        Editor coverage, Copilot, JetBrains, and why budi reads local logs instead of going through
        a proxy. If yours isn't here,
        <a
          href="https://github.com/siropkin/budi/issues"
          target="_blank"
          rel="noopener noreferrer"
          class="link-underline hover:text-fg">open an issue</a
        >.
      </p>
    </header>

    <div class="grid gap-3">
      {
        faqs.map((f, i) => (
          <details class="card group p-5 sm:p-6" open={i === 0}>
            <summary class="text-fg flex cursor-pointer list-none items-start justify-between gap-3 font-semibold tracking-tight">
              <span>{f.q}</span>
              <svg
                aria-hidden="true"
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="text-fg-dim mt-1 shrink-0 transition-transform group-open:rotate-90"
              >
                <polyline points="9 18 15 12 9 6" />
              </svg>
            </summary>
            <p class="text-fg-muted mt-3 text-sm leading-relaxed">{f.a}</p>
          </details>
        ))
      }
    </div>
  </section>
</Base>
