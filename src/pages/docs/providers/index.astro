---
import DocsLayout from "~/layouts/DocsLayout.astro";

const providers = [
  {
    name: "Cursor",
    live: true,
    source: "Local SQLite + Cursor Usage API",
    latency: "~10 min (API) / seconds (local)",
    href: "/docs/providers/cursor/",
    details:
      "Budi reads Cursor's local SQLite database for per-message token counts and model info. The Cursor Usage API supplements this with dollar-level reconciliation.",
  },
  {
    name: "Claude Code",
    live: true,
    source: "Local JSONL transcripts",
    latency: "seconds",
    href: "/docs/providers/claude-code/",
    details:
      "Claude Code writes JSONL transcripts to ~/.claude/projects/. Budi tails these files in real-time for session, token, and cost data.",
  },
  {
    name: "Codex CLI",
    live: true,
    source: "Local JSONL transcripts",
    latency: "seconds",
    href: "/docs/providers/codex-cli/",
    details:
      "OpenAI's Codex CLI writes JSONL session logs. Budi tails these the same way it handles Claude Code transcripts — automatic discovery, real-time attribution.",
  },
  {
    name: "Copilot CLI",
    live: true,
    source: "Local JSONL session-state",
    latency: "seconds",
    href: "/docs/providers/copilot-cli/",
    details:
      "GitHub Copilot's CLI mode writes local session state files. Budi reads these for token counts and model info.",
  },
  {
    name: "Copilot Chat (VS Code)",
    live: true,
    source: "Local JSON/JSONL + GitHub Billing API",
    latency: "seconds (local) / ~hour (billing)",
    href: "/docs/providers/copilot-chat/",
    details:
      "VS Code's Copilot Chat stores local session data that budi tails for output-only token counts. For dollar-accurate reconciliation, add a GitHub PAT scoped to billing.",
  },
  {
    name: "Continue, Cline, Roo Code, Aider, Gemini CLI",
    live: false,
    source: "Local logs (planned)",
    latency: null,
    href: null,
    details:
      "Planned for 8.5.0. Same provider-plugin pattern as Cursor and Copilot Chat — local logs primary, no proxy.",
  },
];
---

<DocsLayout
  title="Providers"
  description="Which AI coding agents budi tracks, how it sources data from each, and what's on the roadmap."
>
  <div class="flex max-w-2xl flex-col gap-10">
    <header>
      <h1 class="text-2xl font-semibold tracking-tight sm:text-3xl">Providers</h1>
      <p class="text-fg-muted mt-3 leading-relaxed">
        Local logs are the primary source for every provider. Vendor APIs (Cursor Usage, GitHub
        Billing) are used only as supplementary truth-up — so attribution keeps working offline and
        when an upstream API breaks.
      </p>
    </header>

    <section>
      <h2 id="coverage-matrix" class="text-fg mb-4 text-xl font-semibold tracking-tight">
        Coverage matrix
      </h2>
      <div class="card overflow-hidden">
        <table class="w-full text-sm">
          <thead class="text-fg-dim border-line/70 border-b text-xs tracking-wider uppercase">
            <tr>
              <th class="px-4 py-3 text-left font-medium sm:px-5">Provider</th>
              <th class="px-4 py-3 text-left font-medium sm:px-5">Status</th>
              <th class="hidden px-4 py-3 text-left font-medium sm:table-cell sm:px-5">Source</th>
              <th class="hidden px-4 py-3 text-left font-medium sm:table-cell sm:px-5">Latency</th>
            </tr>
          </thead>
          <tbody>
            {
              providers.map((p, i) => (
                <tr class:list={[i > 0 ? "border-line/70 border-t" : ""]}>
                  <td class="text-fg px-4 py-3 font-medium sm:px-5">
                    {p.href ? (
                      <a href={p.href} class="link-underline hover:text-accent">
                        {p.name}
                      </a>
                    ) : (
                      p.name
                    )}
                  </td>
                  <td class="px-4 py-3 sm:px-5">
                    <span
                      class:list={["chip", p.live ? "border-accent text-accent" : "text-fg-dim"]}
                    >
                      {p.live ? "Live" : "Coming soon"}
                    </span>
                  </td>
                  <td class="text-fg-muted hidden px-4 py-3 sm:table-cell sm:px-5">{p.source}</td>
                  <td class="text-fg-muted hidden px-4 py-3 sm:table-cell sm:px-5">
                    {p.latency ?? "—"}
                  </td>
                </tr>
              ))
            }
          </tbody>
        </table>
      </div>
    </section>

    {
      providers.map((p) => (
        <section>
          <h2
            id={p.name
              .toLowerCase()
              .replace(/[^a-z0-9]+/g, "-")
              .replace(/-+$/, "")}
            class="text-fg mb-2 text-xl font-semibold tracking-tight"
          >
            {p.href ? (
              <a href={p.href} class="hover:text-accent transition-colors">
                {p.name}
              </a>
            ) : (
              p.name
            )}
          </h2>
          <div class="flex flex-wrap items-center gap-2">
            <span class:list={["chip", p.live ? "border-accent text-accent" : "text-fg-dim"]}>
              {p.live ? "Live" : "Coming soon"}
            </span>
            <span class="text-fg-dim text-xs">{p.source}</span>
          </div>
          <p class="text-fg-muted mt-3 leading-relaxed">{p.details}</p>
          {p.href && (
            <a
              href={p.href}
              class="text-accent hover:text-accent/80 mt-2 inline-flex items-center gap-1.5 text-sm font-medium transition-colors"
            >
              Full guide
              <svg
                aria-hidden="true"
                width="14"
                height="14"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <line x1="5" y1="12" x2="19" y2="12" />
                <polyline points="12 5 19 12 12 19" />
              </svg>
            </a>
          )}
        </section>
      ))
    }

    <section>
      <h2 id="how-it-works" class="text-fg mb-3 text-xl font-semibold tracking-tight">
        How local tailing works
      </h2>
      <p class="text-fg-muted leading-relaxed">
        Budi's daemon watches the transcript and log directories that each agent writes to. It reads
        new lines as they appear — like <code
          class="bg-surface-3 border-line/70 text-fg rounded border px-1.5 py-0.5 text-[0.9em]"
          >tail -f</code
        > but structured. The daemon never injects itself into the request path between your editor and
        the AI provider. This means:
      </p>
      <ul class="text-fg-muted mt-4 space-y-2 text-sm leading-relaxed">
        <li class="flex items-start gap-2.5">
          <span
            aria-hidden="true"
            class="bg-accent mt-[7px] inline-block h-1.5 w-1.5 shrink-0 rounded-full"></span>
          No added latency — the daemon is a passive reader.
        </li>
        <li class="flex items-start gap-2.5">
          <span
            aria-hidden="true"
            class="bg-accent mt-[7px] inline-block h-1.5 w-1.5 shrink-0 rounded-full"></span>
          No proxy or gateway — nothing sits between your editor and the AI model.
        </li>
        <li class="flex items-start gap-2.5">
          <span
            aria-hidden="true"
            class="bg-accent mt-[7px] inline-block h-1.5 w-1.5 shrink-0 rounded-full"></span>
          Works offline — local logs don't depend on network access.
        </li>
        <li class="flex items-start gap-2.5">
          <span
            aria-hidden="true"
            class="bg-accent mt-[7px] inline-block h-1.5 w-1.5 shrink-0 rounded-full"></span>
          Survives API outages — if the vendor API is down, local tailing still works.
        </li>
      </ul>
    </section>

    <section>
      <h2 id="copilot-pat" class="text-fg mb-3 text-xl font-semibold tracking-tight">
        Copilot Chat and GitHub PATs
      </h2>
      <p class="text-fg-muted leading-relaxed">
        Without a PAT, on May-2026+ VS Code builds you get output-only token dollars — useful as a
        relative trend, but typically a fraction of the actual bill. With a PAT scoped to billing,
        budi reconciles to GitHub's exact dollar number per (date, model) bucket.
        <a href="/docs/providers/copilot-chat/#pat-setup" class="link-underline hover:text-fg">
          Full PAT setup guide →
        </a>
      </p>
      <p class="text-fg-muted mt-3 leading-relaxed">
        Org-managed licences see output-only forever — the user-level Billing API endpoint is empty
        for them. This is a GitHub limitation, not a budi one.
      </p>
    </section>
  </div>
</DocsLayout>
