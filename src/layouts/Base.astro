---
import "~/styles/global.css";
import Analytics from "@vercel/analytics/astro";
import GitHubIcon from "~/components/GitHubIcon.astro";
import JsonLd from "~/components/JsonLd.astro";
import { ANCHORS, anchorHref, siteAnchorHref } from "~/lib/anchors";

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  /**
   * Opt a single page out of the sitemap + search indexing. Used by /404,
   * which should resolve but should not show up as an entry point. Note:
   * Vercel preview deploys automatically serve `X-Robots-Tag: noindex`
   * (see vercel.json / platform default), so we do not need to wire
   * environment-based logic here.
   */
  noindex?: boolean;
}

const SITE_URL = "https://getbudi.dev";
const OG_IMAGE = `${SITE_URL}/og.png`;

const {
  title = "budi — AI coding cost tracker for Cursor, VS Code, Claude Code & Codex",
  description = "Free, self-hosted AI coding cost tracker — no signup needed. Cursor, Copilot Chat, Claude Code, Codex, Copilot CLI. Tails local transcripts; cost by repo/branch/ticket. Nothing in your network path.",
  canonical = `${SITE_URL}/`,
  noindex = false,
} = Astro.props;

// JSON-LD lives in `head` so rich-result crawlers pick it up without JS.
// SoftwareApplication is the closest schema.org fit: budi is a CLI tool
// with a GitHub download target, MIT-licensed, and cross-platform.
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "budi",
  description,
  url: SITE_URL,
  applicationCategory: "DeveloperApplication",
  operatingSystem: "macOS, Linux, Windows",
  license: "https://opensource.org/licenses/MIT",
  offers: {
    "@type": "Offer",
    price: "0",
    priceCurrency: "USD",
  },
  downloadUrl: "https://github.com/siropkin/budi/releases",
  codeRepository: "https://github.com/siropkin/budi",
  author: {
    "@type": "Person",
    name: "Ivan Seredkin",
    url: "https://github.com/siropkin",
  },
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex,follow" />}

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="budi" />
    <meta property="og:image" content={OG_IMAGE} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta
      property="og:image:alt"
      content="budi — see where your AI coding money actually goes. Install with brew install siropkin/budi/budi && budi init."
    />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={OG_IMAGE} />
    <meta
      name="twitter:image:alt"
      content="budi — local-first cost tracker for AI coding agents."
    />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="192x192" href="/icon-192.png" />
    <link rel="icon" type="image/png" sizes="512x512" href="/icon-512.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

    <meta name="theme-color" content="#0b0d10" />

    <JsonLd data={jsonLd} />
  </head>
  <body class="antialiased">
    <a
      href={anchorHref(ANCHORS.main)}
      class="focus:bg-accent sr-only focus:not-sr-only focus:absolute focus:top-3 focus:left-3 focus:z-50 focus:rounded-md focus:px-3 focus:py-2 focus:text-white"
    >
      Skip to content
    </a>

    <header class="border-line/70 border-b backdrop-blur-sm">
      <div class="container-readable flex items-center justify-between py-4">
        <a href="/" class="flex items-center gap-2 font-semibold tracking-tight">
          <span
            aria-hidden="true"
            class="bg-accent inline-block h-2.5 w-2.5 rounded-full shadow-[0_0_10px_var(--color-accent)]"
          ></span>
          <span class="text-[1.05rem]">budi</span>
          <span class="text-fg-dim text-xs font-normal">/ getbudi.dev</span>
        </a>
        <nav class="text-fg-muted flex items-center gap-3 text-sm sm:gap-5">
          <a href={siteAnchorHref(ANCHORS.install)} class="hover:text-fg hidden sm:inline"
            >Install</a
          >
          <a href={siteAnchorHref(ANCHORS.providers)} class="hover:text-fg hidden md:inline"
            >Providers</a
          >
          <a href={siteAnchorHref(ANCHORS.compare)} class="hover:text-fg hidden sm:inline"
            >Compare</a
          >
          <a href={siteAnchorHref(ANCHORS.privacy)} class="hover:text-fg hidden sm:inline"
            >Privacy</a
          >
          <a href={siteAnchorHref(ANCHORS.teams)} class="hover:text-fg hidden md:inline">Cloud</a>
          <a href={siteAnchorHref(ANCHORS.faq)} class="hover:text-fg hidden md:inline">FAQ</a>
          <details class="relative sm:hidden">
            <summary
              class="hover:text-fg flex cursor-pointer list-none items-center gap-1"
              aria-label="Open sections menu"
            >
              Sections
              <svg
                aria-hidden="true"
                width="10"
                height="10"
                viewBox="0 0 12 12"
                fill="currentColor"
              >
                <path d="M2 4l4 4 4-4z"></path>
              </svg>
            </summary>
            <div
              class="border-line/70 bg-surface-2 absolute top-full right-0 z-20 mt-2 flex min-w-[160px] flex-col gap-2 rounded-md border p-3 shadow-lg"
            >
              <a href={siteAnchorHref(ANCHORS.install)} class="hover:text-fg">Install</a>
              <a href={siteAnchorHref(ANCHORS.providers)} class="hover:text-fg">Providers</a>
              <a href={siteAnchorHref(ANCHORS.compare)} class="hover:text-fg">Compare</a>
              <a href={siteAnchorHref(ANCHORS.privacy)} class="hover:text-fg">Privacy</a>
              <a href={siteAnchorHref(ANCHORS.teams)} class="hover:text-fg">Cloud</a>
              <a href={siteAnchorHref(ANCHORS.faq)} class="hover:text-fg">FAQ</a>
              <hr class="border-line/70" />
              <a href="/login" class="text-accent hover:text-accent/85 font-medium">Sign in</a>
            </div>
          </details>
          <a
            href="https://github.com/siropkin/budi"
            class="hover:text-fg flex items-center gap-1.5"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Budi on GitHub"
          >
            <GitHubIcon />
            <span class="hidden sm:inline">GitHub</span>
          </a>
          <a
            href="/login"
            class="bg-accent hover:bg-accent/85 hidden rounded-md px-3 py-1.5 text-sm font-medium text-white transition-colors sm:inline-block"
          >
            Sign in
          </a>
        </nav>
      </div>
    </header>

    <main id={ANCHORS.main} tabindex="-1">
      <slot />
    </main>

    <Analytics />

    <footer class="border-line/70 mt-24 border-t">
      <div class="container-readable text-fg-muted py-10 text-sm">
        <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
          <div>
            <div class="text-fg mb-2 flex items-center gap-2 font-semibold">
              <span aria-hidden="true" class="bg-accent inline-block h-2 w-2 rounded-full"></span>
              budi
            </div>
            <p>Local-first cost analytics for AI coding agents. MIT-licensed, open source.</p>
          </div>
          <div>
            <h4 class="text-fg mb-2 font-medium">Source</h4>
            <ul class="space-y-1.5">
              <li>
                <a
                  href="https://github.com/siropkin/budi"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="hover:text-fg">budi (core)</a
                >
              </li>
              <li>
                <a
                  href="https://github.com/siropkin/budi-cloud"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="hover:text-fg">budi-cloud</a
                >
              </li>
              <li>
                <a
                  href="https://github.com/siropkin/budi-cursor"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="hover:text-fg">budi-cursor</a
                >
              </li>
              <li>
                <a
                  href="https://github.com/siropkin/homebrew-budi"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="hover:text-fg">homebrew-budi</a
                >
              </li>
            </ul>
          </div>
          <div>
            <h4 class="text-fg mb-2 font-medium">Reference</h4>
            <ul class="space-y-1.5">
              <li>
                <a
                  href="https://github.com/siropkin/budi#readme"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="hover:text-fg">README</a
                >
              </li>
              <li>
                <a
                  href="https://github.com/siropkin/budi/releases"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="hover:text-fg">Changelog (Releases)</a
                >
              </li>
            </ul>
          </div>
          <div>
            <h4 class="text-fg mb-2 font-medium">Project</h4>
            <ul class="space-y-1.5">
              <li>
                <a
                  href="https://github.com/siropkin/budi/blob/main/LICENSE"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="hover:text-fg">License (MIT)</a
                >
              </li>
              <li>
                <a
                  href="https://app.getbudi.dev"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="hover:text-fg">app.getbudi.dev</a
                >
              </li>
              <li>
                <a
                  href="https://github.com/siropkin/budi/issues"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="hover:text-fg">Issues</a
                >
              </li>
            </ul>
          </div>
        </div>
        <div
          class="border-line/70 text-fg-dim mt-10 flex flex-col justify-between gap-3 border-t pt-6 text-xs sm:flex-row"
        >
          <span>© {new Date().getFullYear()} budi contributors. Public alpha.</span>
          <span>
            Built static.{" "}
            <a href={siteAnchorHref(ANCHORS.analytics)} class="link-underline hover:text-fg"
              >Privacy-friendly analytics via Vercel</a
            >. Source on{" "}
            <a
              href="https://github.com/siropkin/getbudi.dev"
              target="_blank"
              rel="noopener noreferrer"
              class="link-underline hover:text-fg">GitHub</a
            >.
          </span>
        </div>
      </div>
    </footer>
  </body>
</html>
