---
import "~/styles/global.css";
import Analytics from "@vercel/analytics/astro";

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  /**
   * Opt a single page out of the sitemap + search indexing. Used by /404,
   * which should resolve but should not show up as an entry point. Note:
   * Vercel preview deploys automatically serve `X-Robots-Tag: noindex`
   * (see vercel.json / platform default), so we do not need to wire
   * environment-based logic here.
   */
  noindex?: boolean;
}

const SITE_URL = "https://getbudi.dev";
const OG_IMAGE = `${SITE_URL}/og.png`;

const {
  title = "budi — AI coding cost tracker for Claude Code, Cursor & Codex",
  description = "AI coding cost tracker for Claude Code, Cursor, Codex, and Copilot. Local-first Rust daemon tails agent transcripts — cost by repo, branch, and ticket. Nothing in your network path.",
  canonical = `${SITE_URL}/`,
  noindex = false,
} = Astro.props;

// JSON-LD lives in `head` so rich-result crawlers pick it up without JS.
// SoftwareApplication is the closest schema.org fit: budi is a CLI tool
// with a GitHub download target, MIT-licensed, and cross-platform.
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "budi",
  description,
  url: SITE_URL,
  applicationCategory: "DeveloperApplication",
  operatingSystem: "macOS, Linux, Windows",
  license: "https://opensource.org/licenses/MIT",
  offers: {
    "@type": "Offer",
    price: "0",
    priceCurrency: "USD",
  },
  downloadUrl: "https://github.com/siropkin/budi/releases",
  codeRepository: "https://github.com/siropkin/budi",
  author: {
    "@type": "Person",
    name: "Ivan Seredkin",
    url: "https://github.com/siropkin",
  },
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex,follow" />}

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="budi" />
    <meta property="og:image" content={OG_IMAGE} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta
      property="og:image:alt"
      content="budi — see where your AI coding money actually goes. Install with brew install siropkin/budi/budi && budi init."
    />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={OG_IMAGE} />
    <meta
      name="twitter:image:alt"
      content="budi — local-first cost tracker for AI coding agents."
    />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="192x192" href="/icon-192.png" />
    <link rel="icon" type="image/png" sizes="512x512" href="/icon-512.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

    <meta name="theme-color" content="#0b0d10" />

    <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />
  </head>
  <body class="antialiased">
    <a
      href="#main"
      class="focus:bg-accent sr-only focus:not-sr-only focus:absolute focus:top-3 focus:left-3 focus:z-50 focus:rounded-md focus:px-3 focus:py-2 focus:text-black"
    >
      Skip to content
    </a>

    <header class="border-line/70 border-b backdrop-blur-sm">
      <div class="container-readable flex items-center justify-between py-4">
        <a href="/" class="flex items-center gap-2 font-semibold tracking-tight">
          <span
            aria-hidden="true"
            class="bg-accent inline-block h-2.5 w-2.5 rounded-full shadow-[0_0_10px_var(--color-accent)]"
          ></span>
          <span class="text-[1.05rem]">budi</span>
          <span class="text-fg-dim text-xs font-normal">/ getbudi.dev</span>
        </a>
        <nav class="text-fg-muted flex items-center gap-5 text-sm">
          <a href="/#install" class="hover:text-fg">Install</a>
          <a href="/#compare" class="hover:text-fg hidden sm:inline">Compare</a>
          <a href="/#privacy" class="hover:text-fg hidden sm:inline">Privacy</a>
          <a href="/#teams" class="hover:text-fg hidden md:inline">For teams</a>
          <a
            href="https://github.com/siropkin/budi"
            class="hover:text-fg flex items-center gap-1.5"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Budi on GitHub"
          >
            <svg aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
              <path
                d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.11.79-.25.79-.56v-2.18c-3.2.7-3.87-1.36-3.87-1.36-.52-1.32-1.27-1.67-1.27-1.67-1.04-.71.08-.7.08-.7 1.15.08 1.76 1.18 1.76 1.18 1.02 1.76 2.69 1.25 3.35.96.1-.74.4-1.25.72-1.54-2.55-.29-5.24-1.28-5.24-5.7 0-1.26.45-2.29 1.18-3.1-.12-.29-.51-1.46.11-3.05 0 0 .97-.31 3.18 1.18a11 11 0 0 1 5.79 0c2.21-1.49 3.18-1.18 3.18-1.18.62 1.59.23 2.76.12 3.05.74.81 1.18 1.84 1.18 3.1 0 4.43-2.69 5.4-5.26 5.69.41.36.78 1.06.78 2.14v3.17c0 .31.21.68.8.56C20.21 21.39 23.5 17.08 23.5 12 23.5 5.65 18.35.5 12 .5z"
              ></path>
            </svg>
            <span class="hidden sm:inline">GitHub</span>
          </a>
        </nav>
      </div>
    </header>

    <main id="main">
      <slot />
    </main>

    <Analytics />

    <footer class="border-line/70 mt-24 border-t">
      <div class="container-readable text-fg-muted py-10 text-sm">
        <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
          <div>
            <div class="text-fg mb-2 flex items-center gap-2 font-semibold">
              <span aria-hidden="true" class="bg-accent inline-block h-2 w-2 rounded-full"></span>
              budi
            </div>
            <p>Local-first cost analytics for AI coding agents. MIT-licensed, open source.</p>
          </div>
          <div>
            <h4 class="text-fg mb-2 font-medium">Source</h4>
            <ul class="space-y-1.5">
              <li>
                <a
                  href="https://github.com/siropkin/budi"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="hover:text-fg">budi (core)</a
                >
              </li>
              <li>
                <a
                  href="https://github.com/siropkin/budi-cloud"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="hover:text-fg">budi-cloud</a
                >
              </li>
              <li>
                <a
                  href="https://github.com/siropkin/budi-cursor"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="hover:text-fg">budi-cursor</a
                >
              </li>
              <li>
                <a
                  href="https://github.com/siropkin/homebrew-budi"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="hover:text-fg">homebrew-budi</a
                >
              </li>
            </ul>
          </div>
          <div>
            <h4 class="text-fg mb-2 font-medium">Reference</h4>
            <ul class="space-y-1.5">
              <li>
                <a
                  href="https://github.com/siropkin/budi#readme"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="hover:text-fg">README</a
                >
              </li>
              <li>
                <a
                  href="https://github.com/siropkin/budi/releases"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="hover:text-fg">Changelog (Releases)</a
                >
              </li>
            </ul>
          </div>
          <div>
            <h4 class="text-fg mb-2 font-medium">Project</h4>
            <ul class="space-y-1.5">
              <li>
                <a
                  href="https://github.com/siropkin/budi/blob/main/LICENSE"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="hover:text-fg">License (MIT)</a
                >
              </li>
              <li>
                <a
                  href="https://app.getbudi.dev"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="hover:text-fg">app.getbudi.dev</a
                >
              </li>
              <li>
                <a
                  href="https://github.com/siropkin/budi/issues"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="hover:text-fg">Issues</a
                >
              </li>
            </ul>
          </div>
        </div>
        <div
          class="border-line/70 text-fg-dim mt-10 flex flex-col justify-between gap-3 border-t pt-6 text-xs sm:flex-row"
        >
          <span>© {new Date().getFullYear()} budi contributors. Public alpha.</span>
          <span>
            Built static.{" "}
            <a href="/#analytics" class="link-underline hover:text-fg"
              >Privacy-friendly analytics via Vercel</a
            >. Source on{" "}
            <a
              href="https://github.com/siropkin/getbudi.dev"
              target="_blank"
              rel="noopener noreferrer"
              class="link-underline hover:text-fg">GitHub</a
            >.
          </span>
        </div>
      </div>
    </footer>
  </body>
</html>
