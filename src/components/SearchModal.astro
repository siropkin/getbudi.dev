---

---

<button
  id="search-trigger"
  type="button"
  aria-label="Search site (⌘K)"
  class="hover:text-fg border-line/70 hover:border-line-strong hidden items-center gap-2 rounded-md border px-2.5 py-1 text-sm transition-colors sm:flex"
>
  <svg
    aria-hidden="true"
    width="14"
    height="14"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
  >
    <circle cx="11" cy="11" r="8"></circle>
    <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
  </svg>
  <span class="text-fg-muted">Search</span>
  <kbd class="text-fg-dim bg-surface-2 rounded px-1.5 py-0.5 text-xs">⌘K</kbd>
</button>

<dialog
  id="search-dialog"
  class="bg-surface-2 border-line/70 m-0 mx-auto mt-[min(20vh,8rem)] w-full max-w-lg rounded-xl border p-0 shadow-2xl backdrop:bg-black/60"
>
  <div class="flex flex-col">
    <div class="border-line/70 flex items-center gap-3 border-b px-4 py-3">
      <svg
        aria-hidden="true"
        class="text-fg-muted shrink-0"
        width="18"
        height="18"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <circle cx="11" cy="11" r="8"></circle>
        <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
      </svg>
      <input
        id="search-input"
        type="text"
        placeholder="Search docs and pages…"
        autocomplete="off"
        class="text-fg placeholder:text-fg-dim min-w-0 flex-1 bg-transparent text-sm outline-none"
      />
      <kbd class="text-fg-dim border-line/70 shrink-0 rounded border px-1.5 py-0.5 text-xs">Esc</kbd
      >
    </div>
    <div id="search-results" class="max-h-[min(60vh,24rem)] overflow-y-auto p-2">
      <div id="search-empty" class="text-fg-muted px-2 py-8 text-center text-sm">
        Type to search…
      </div>
    </div>
  </div>
</dialog>

<script>
  const dialog = document.getElementById("search-dialog") as HTMLDialogElement;
  const input = document.getElementById("search-input") as HTMLInputElement;
  const results = document.getElementById("search-results") as HTMLDivElement;
  const empty = document.getElementById("search-empty") as HTMLDivElement;
  const trigger = document.getElementById("search-trigger") as HTMLButtonElement;

  let pagefind: any = null;
  let activeIndex = -1;
  let debounceTimer: ReturnType<typeof setTimeout>;

  let loadFailed = false;

  async function loadPagefind() {
    if (pagefind) return pagefind;
    if (loadFailed) return null;
    try {
      const path = "/pagefind/pagefind.js";
      const pf = await import(/* @vite-ignore */ path);
      pagefind = await pf.createInstance({ noWorker: true, basePath: "/pagefind/" });
      return pagefind;
    } catch {
      loadFailed = true;
      return null;
    }
  }

  function showError() {
    results.innerHTML = "";
    results.appendChild(empty);
    empty.textContent = "Search unavailable — please hard-refresh (⌘⇧R)";
    activeIndex = -1;
  }

  function open() {
    dialog.showModal();
    input.value = "";
    results.innerHTML = "";
    results.appendChild(empty);
    empty.textContent = loadFailed
      ? "Search unavailable — please hard-refresh (⌘⇧R)"
      : "Type to search…";
    activeIndex = -1;
    input.focus();
  }

  function close() {
    dialog.close();
  }

  function getResultLinks(): HTMLAnchorElement[] {
    return Array.from(results.querySelectorAll("a[data-search-result]"));
  }

  function setActive(index: number) {
    const links = getResultLinks();
    if (links.length === 0) return;
    activeIndex = ((index % links.length) + links.length) % links.length;
    links.forEach((link, i) => {
      link.classList.toggle("bg-accent/15", i === activeIndex);
      link.classList.toggle("text-fg", i === activeIndex);
      if (i === activeIndex) link.scrollIntoView({ block: "nearest" });
    });
  }

  async function search(query: string) {
    if (!query.trim()) {
      results.innerHTML = "";
      results.appendChild(empty);
      empty.textContent = loadFailed
        ? "Search unavailable — please hard-refresh (⌘⇧R)"
        : "Type to search…";
      activeIndex = -1;
      return;
    }

    const pf = await loadPagefind();
    if (!pf) {
      showError();
      return;
    }

    let searchResults;
    try {
      searchResults = await pf.search(query);
    } catch {
      showError();
      return;
    }

    if (searchResults.results.length === 0) {
      results.innerHTML = "";
      results.appendChild(empty);
      empty.textContent = "No results found.";
      activeIndex = -1;
      return;
    }

    const items = await Promise.all(searchResults.results.slice(0, 12).map((r: any) => r.data()));

    results.innerHTML = "";
    for (const item of items) {
      const link = document.createElement("a");
      link.href = item.url;
      link.dataset.searchResult = "";
      link.className =
        "flex flex-col gap-0.5 rounded-lg px-3 py-2.5 text-sm text-fg-muted transition-colors hover:bg-accent/15 hover:text-fg cursor-pointer";

      const title = document.createElement("span");
      title.className = "font-medium text-fg";
      title.textContent = item.meta?.title || item.url;
      link.appendChild(title);

      if (item.excerpt) {
        const excerpt = document.createElement("span");
        excerpt.className = "text-fg-dim line-clamp-2 text-xs";
        excerpt.innerHTML = item.excerpt;
        link.appendChild(excerpt);
      }

      link.addEventListener("click", () => close());
      results.appendChild(link);
    }

    activeIndex = -1;
  }

  input.addEventListener("input", () => {
    clearTimeout(debounceTimer);
    debounceTimer = setTimeout(() => search(input.value), 150);
  });

  input.addEventListener("keydown", (e) => {
    const links = getResultLinks();
    if (e.key === "ArrowDown") {
      e.preventDefault();
      setActive(activeIndex + 1);
    } else if (e.key === "ArrowUp") {
      e.preventDefault();
      setActive(activeIndex - 1);
    } else if (e.key === "Enter" && activeIndex >= 0 && activeIndex < links.length) {
      e.preventDefault();
      links[activeIndex]!.click();
    }
  });

  trigger.addEventListener("click", open);

  dialog.addEventListener("click", (e) => {
    if (e.target === dialog) close();
  });

  document.addEventListener("keydown", (e) => {
    if ((e.metaKey || e.ctrlKey) && e.key === "k") {
      e.preventDefault();
      if (dialog.open) {
        close();
      } else {
        open();
      }
    }
  });
</script>
