---
interface Props {
  command: string;
  variant?: "hero" | "compact";
}

const { command, variant = "hero" } = Astro.props;
const isHero = variant === "hero";
---

<div
  class:list={[
    "copyable group relative flex w-full items-stretch overflow-hidden",
    "border-line bg-surface-2 rounded-xl border",
    "shadow-[0_1px_0_rgba(255,255,255,0.04)_inset,0_8px_30px_-12px_rgba(0,0,0,0.5)]",
    isHero ? "text-base" : "text-sm",
  ]}
  data-command={command}
>
  <span
    aria-hidden="true"
    class:list={[
      "border-line/70 border-r select-none",
      "text-accent flex items-center px-3 font-mono sm:px-4",
      isHero ? "py-3.5" : "py-2.5",
    ]}
  >
    $
  </span>
  <pre
    class:list={[
      "m-0 flex-1 overflow-x-auto px-3 py-3.5 font-mono whitespace-pre sm:px-4",
      "text-fg",
      isHero ? "text-[0.95rem] sm:text-base" : "text-sm",
    ]}><code>{command}</code></pre>
  <button
    type="button"
    aria-label="Copy install command"
    class:list={[
      "copyable-btn border-line/70 shrink-0 border-l px-3 sm:px-4",
      "text-xs font-semibold tracking-wider uppercase",
      "text-fg-muted hover:text-accent hover:bg-accent-soft",
      "flex items-center gap-1.5 transition-colors",
    ]}
  >
    <svg
      aria-hidden="true"
      width="14"
      height="14"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
      <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
    </svg>
    <span class="copyable-label">Copy</span>
  </button>
</div>

<script>
  const blocks = document.querySelectorAll<HTMLElement>(".copyable");
  for (const block of blocks) {
    const button = block.querySelector<HTMLButtonElement>(".copyable-btn");
    const label = block.querySelector<HTMLElement>(".copyable-label");
    const command = block.dataset.command ?? "";
    if (!button || !label) continue;

    button.addEventListener("click", async () => {
      try {
        await navigator.clipboard.writeText(command);
        const original = label.textContent;
        label.textContent = "Copied";
        button.classList.add("text-accent");
        setTimeout(() => {
          label.textContent = original ?? "Copy";
          button.classList.remove("text-accent");
        }, 1600);
      } catch {
        label.textContent = "Press ⌘C";
        setTimeout(() => {
          label.textContent = "Copy";
        }, 2000);
      }
    });
  }
</script>
