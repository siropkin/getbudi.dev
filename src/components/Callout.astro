---
/** Tinted callout box with left border accent. Kinds: info (blue), tip (green), warn (yellow). */
interface Props {
  kind: "info" | "tip" | "warn";
  title?: string;
}

const { kind, title } = Astro.props;

const styles = {
  info: "border-l-accent bg-accent-soft",
  tip: "border-l-tip bg-tip-soft",
  warn: "border-l-warn bg-warn-soft",
} as const;
---

<div class:list={["rounded-lg border-l-4 p-5", styles[kind]]}>
  <div class="flex items-start gap-3">
    {
      kind === "info" && (
        <svg
          aria-hidden="true"
          class="text-accent mt-0.5 h-4 w-4 shrink-0"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <circle cx="12" cy="12" r="10" />
          <line x1="12" y1="16" x2="12" y2="12" />
          <line x1="12" y1="8" x2="12.01" y2="8" />
        </svg>
      )
    }
    {
      kind === "tip" && (
        <svg
          aria-hidden="true"
          class="text-tip mt-0.5 h-4 w-4 shrink-0"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <line x1="9" y1="18" x2="15" y2="18" />
          <line x1="10" y1="22" x2="14" y2="22" />
          <path d="M15.09 14c.18-.98.65-1.74 1.41-2.5A4.65 4.65 0 0 0 18 8 6 6 0 0 0 6 8c0 1 .23 2.23 1.5 3.5A4.61 4.61 0 0 1 8.91 14" />
        </svg>
      )
    }
    {
      kind === "warn" && (
        <svg
          aria-hidden="true"
          class="text-warn mt-0.5 h-4 w-4 shrink-0"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z" />
          <line x1="12" y1="9" x2="12" y2="13" />
          <line x1="12" y1="17" x2="12.01" y2="17" />
        </svg>
      )
    }
    <div>
      {title && <h3 class="text-fg mb-1 font-semibold">{title}</h3>}
      <div class="text-fg-muted text-sm leading-relaxed">
        <slot />
      </div>
    </div>
  </div>
</div>
