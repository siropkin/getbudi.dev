---
import CodeTabs from "./CodeTabs.astro";

interface Props {
  commands: {
    macos: string;
    linux: string;
    windows: string;
  };
  variant?: "hero" | "compact";
  id: string;
}

const { commands, variant = "hero", id } = Astro.props;

const tabs = [
  { key: "macos", label: "macOS", icon: "apple" as const, code: commands.macos },
  { key: "linux", label: "Linux", icon: "linux" as const, code: commands.linux },
  { key: "windows", label: "Windows", icon: "windows" as const, code: commands.windows },
];
---

<div data-os-install>
  <CodeTabs tabs={tabs} variant={variant} id={id} />
</div>

<script>
  type OS = "macos" | "linux" | "windows";

  function detectOS(): OS {
    const uaData = (navigator as Navigator & { userAgentData?: { platform?: string } })
      .userAgentData;
    const probe = `${uaData?.platform ?? ""} ${navigator.userAgent ?? ""}`.toLowerCase();
    if (probe.includes("mac")) return "macos";
    if (probe.includes("win")) return "windows";
    if (probe.includes("linux") && !probe.includes("android")) return "linux";
    return "macos";
  }

  const detected = detectOS();
  if (detected !== "macos") {
    for (const group of document.querySelectorAll<HTMLElement>("[data-os-install]")) {
      const tabs = group.querySelectorAll<HTMLButtonElement>("[role='tab']");
      const panels = group.querySelectorAll<HTMLElement>("[role='tabpanel']");
      for (const tab of tabs) {
        const active = tab.dataset.tabKey === detected;
        tab.setAttribute("aria-selected", String(active));
        tab.tabIndex = active ? 0 : -1;
      }
      for (const panel of panels) {
        panel.hidden = panel.dataset.tabPanel !== detected;
      }
    }
  }
</script>
