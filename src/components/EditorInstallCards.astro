---
import CopyableCommand from "./CopyableCommand.astro";

const editors = [
  {
    id: "vscode",
    name: "VS Code",
    command: "code --install-extension siropkin.budi",
    installUrl: "vscode:extension/siropkin.budi",
    installLabel: "Install in VS Code",
    storeUrl: "https://marketplace.visualstudio.com/items?itemName=siropkin.budi",
    storeName: "VS Code Marketplace",
    badgeUrl: "https://vsmarketplacebadges.dev/installs-short/siropkin.budi.svg?color=007faf",
    badgeAlt: "VS Code Marketplace install count",
  },
  {
    id: "cursor",
    name: "Cursor",
    command: "cursor --install-extension siropkin.budi",
    installUrl: "https://open-vsx.org/extension/siropkin/budi",
    installLabel: "Install from Open VSX",
    storeUrl: "https://open-vsx.org/extension/siropkin/budi",
    storeName: "Open VSX",
    badgeUrl: "https://img.shields.io/open-vsx/dt/siropkin/budi?label=downloads&color=007faf",
    badgeAlt: "Open VSX download count",
  },
  {
    id: "jetbrains",
    name: "JetBrains IDEs",
    command: null,
    installUrl: "https://plugins.jetbrains.com/plugin/31662-budi",
    installLabel: "Install from Marketplace",
    storeUrl: "https://plugins.jetbrains.com/plugin/31662-budi",
    storeName: "JetBrains Marketplace",
    badgeUrl: "https://img.shields.io/jetbrains/plugin/d/31662-budi?label=downloads&color=007faf",
    badgeAlt: "JetBrains Marketplace download count",
  },
] as const;
---

<div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
  {
    editors.map((ed) => (
      <article class="card flex min-w-0 flex-col gap-3 p-5 sm:p-6">
        <header class="flex items-center gap-3">
          {ed.id === "vscode" ? (
            <svg
              aria-hidden="true"
              width="22"
              height="22"
              viewBox="0 0 24 24"
              fill="currentColor"
              class="text-fg"
            >
              <path d="M23.15 2.587L18.21.21a1.494 1.494 0 0 0-1.705.29l-9.46 8.63-4.12-3.128a.999.999 0 0 0-1.276.057L.327 7.261A1 1 0 0 0 .326 8.74L3.899 12 .326 15.26a1 1 0 0 0 .001 1.479L1.65 17.94a.999.999 0 0 0 1.276.057l4.12-3.128 9.46 8.63a1.492 1.492 0 0 0 1.704.29l4.942-2.377A1.5 1.5 0 0 0 24 20.06V3.939a1.5 1.5 0 0 0-.85-1.352zm-5.146 14.861L10.826 12l7.178-5.448v10.896z" />
            </svg>
          ) : ed.id === "cursor" ? (
            <svg
              aria-hidden="true"
              width="22"
              height="22"
              viewBox="0 0 24 24"
              fill="currentColor"
              class="text-fg"
            >
              <path d="M11.503.131 1.891 5.678a.84.84 0 0 0-.42.726v11.188c0 .3.162.575.42.724l9.609 5.55a1 1 0 0 0 .998 0l9.61-5.55a.84.84 0 0 0 .42-.724V6.404a.84.84 0 0 0-.42-.726L12.497.131a1.01 1.01 0 0 0-.996 0M2.657 6.338h18.55c.263 0 .43.287.297.515L12.23 22.918c-.062.107-.229.064-.229-.06V12.335a.59.59 0 0 0-.295-.51l-9.11-5.257c-.109-.063-.064-.23.061-.23" />
            </svg>
          ) : (
            <svg
              aria-hidden="true"
              width="22"
              height="22"
              viewBox="0 0 24 24"
              fill="currentColor"
              class="text-fg"
            >
              <path d="M2.345 23.997A2.347 2.347 0 0 1 0 21.652V10.988C0 9.665.535 8.37 1.473 7.433l5.965-5.961A5.01 5.01 0 0 1 10.989 0h10.666A2.347 2.347 0 0 1 24 2.345v10.664a5.056 5.056 0 0 1-1.473 3.554l-5.965 5.965A5.017 5.017 0 0 1 13.007 24v-.003H2.345Zm8.969-6.854H5.486v1.371h5.828v-1.371ZM3.963 6.514h13.523v13.519l4.257-4.257a3.936 3.936 0 0 0 1.146-2.767V2.345c0-.678-.552-1.234-1.234-1.234H10.989a3.897 3.897 0 0 0-2.767 1.145L3.963 6.514Zm-.192.192L2.256 8.22a3.944 3.944 0 0 0-1.145 2.768v10.664c0 .678.552 1.234 1.234 1.234h10.666a3.9 3.9 0 0 0 2.767-1.146l1.512-1.511H3.771V6.706Z" />
            </svg>
          )}
          <h3 class="text-fg min-w-0 leading-tight font-semibold tracking-tight">{ed.name}</h3>
        </header>

        <a href={ed.storeUrl} target="_blank" rel="noopener noreferrer">
          <img
            src={ed.badgeUrl}
            alt={ed.badgeAlt}
            height="20"
            loading="lazy"
          />
        </a>

        <a
          href={ed.installUrl}
          target={ed.id === "vscode" ? undefined : "_blank"}
          rel={ed.id === "vscode" ? undefined : "noopener noreferrer"}
          class="bg-accent-soft text-accent hover:bg-accent/20 inline-flex items-center gap-2 self-start rounded-lg px-3.5 py-2 text-sm font-medium transition-colors"
        >
          {ed.installLabel}
          <svg aria-hidden="true" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14" /><path d="m12 5 7 7-7 7" />
          </svg>
        </a>

        {ed.command && (
          <CopyableCommand command={ed.command} variant="compact" />
        )}
      </article>
    ))
  }
</div>
